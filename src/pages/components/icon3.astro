---
// empty frontmatter for future use
---

<style>
  #bird {
    width: 64px;
    height: 64px;
    stroke: #4f83c2; 
    fill: #b9d7f5; 
    cursor: default;
    filter: drop-shadow(0 0 6px rgba(79, 131, 194, 0.18));
  }

  .beak {
    stroke: #e58b2a;
    fill: none;
  }

  .eye {
    fill: #000;
    stroke: none;
  }
</style>

<!-- Bird icon -->
<svg 
  id="bird"
  xmlns="http://www.w3.org/2000/svg"
  width="64"
  height="64"
  viewBox="0 0 24 24"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>

  <!-- body -->
  <path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20"/>
  <path d="M10 18v3" fill="none"/>
  <path d="M14 17.75V21" fill="none"/>
  <path d="M7 18a6 6 0 0 0 3.84-10.61"/>

  <!-- beak -->
  <path class="beak" d="m20 7 2 .5-2 .5"/>

  <!-- eye -->
  <circle class="eye" cx="16" cy="7" r="0.8"/>
</svg>

<!-- GSAP -->
<script>
  import gsap from "gsap";

  // subtle flying motion
  gsap.to("#bird", {
    duration: 2,
    x: 8,
    y: -2,
    scale: 1.03,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut",
    transformOrigin: "center center"
  });

  const bird = document.querySelector("#bird");

  // hover lift
  bird.addEventListener("mouseenter", () => {
    gsap.to("#bird", {
      y: -4,
      duration: 0.3,
      ease: "power2.out"
    });
  });

  bird.addEventListener("mouseleave", () => {
    gsap.to("#bird", {
      y: 0,
      duration: 0.3,
      ease: "power2.inOut"
    });
  });
</script>