---
// empty frontmatter for future use
---

<style>
  #tree {
    width: 72px;
    height: 72px;
    cursor: default;
    filter: drop-shadow(0 0 6px rgba(52, 104, 58, 0.18));
  }

  .tree-top {
    stroke: #34683a; /* dark green outline */
    fill: #9ed39e; /* light green fill */
  }

  .tree-trunk {
    stroke: #6b4423;
    fill: #b88a68;
  }
</style>

<!-- tree icon -->
<svg 
  id="tree"
  xmlns="http://www.w3.org/2000/svg"
  width="72"
  height="72"
  viewBox="0 0 24 24"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>

  <!-- tree top -->
  <path 
    class="tree-top"
    d="m17 14 3 3.3a1 1 0 0 1-.7 1.7H4.7a1 1 0 0 1-.7-1.7L7 14h-.3a1 1 0 0 1-.7-1.7L9 9h-.2A1 1 0 0 1 8 7.3L12 3l4 4.3a1 1 0 0 1-.8 1.7H15l3 3.3a1 1 0 0 1-.7 1.7H17Z"
  />

  <!-- trunk -->
  <path 
    class="tree-trunk"
    d="M12 22v-3"
  />
</svg>

<!-- GSAP -->
<script>
  import gsap from "gsap";

  // intro pop animation
  gsap.from("#tree", {
    scale: 2,
    opacity: 0,
    transformOrigin: "center center",
    duration: 0.7,
    ease: "elastic.out(1, 0.5)"
  });

  const tree = document.querySelector("#tree");

  // hover sway
  tree.addEventListener("mouseenter", () => {
    gsap.to("#tree", {
      rotation: 10,
      y: -2,
      duration: 0.35,
      ease: "power2.out",
      transformOrigin: "bottom center"
    });
  });

  tree.addEventListener("mouseleave", () => {
    gsap.to("#tree", {
      rotation: 0,
      y: 0,
      duration: 0.35,
      ease: "power2.inOut"
    });
  });
</script>